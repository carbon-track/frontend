# Turnstile Configuration (Cloudflare)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAA0wcgSIUML5Ocs3

# App Configuration
VITE_APP_NAME=CarbonTrack
VITE_APP_VERSION=3.0.0

# Feature Flags
VITE_ENABLE_PASSKEY=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false

# CDN/Assets
VITE_ASSETS_URL=
VITE_UPLOAD_URL=

# Default Language
VITE_DEFAULT_LANGUAGE=zh

# Contact Emails
VITE_SUPPORT_EMAIL=carbontrack666@gmail.com
VITE_PRIVACY_EMAIL=privacy@carbontrackapp.com
VITE_LEGAL_EMAIL=legal@carbontrackapp.com
VITE_SECURITY_EMAIL=security@carbontrackapp.com

# Dev-only auth bootstrap (仅本地开发环境生效)
# 将登录接口返回的 token 填入 VITE_DEV_AUTH_TOKEN
# 将登录接口返回的 user JSON 进行 Base64 编码后填入 VITE_DEV_AUTH_USER_INFO_BASE64
# 也可直接填入 VITE_DEV_AUTH_USER_INFO_JSON（需是合法 JSON 字符串）
# ⚠️ 切勿在生产环境启用
VITE_ENABLE_DEV_AUTH_FROM_ENV=false
VITE_DEV_AUTH_TOKEN=
VITE_DEV_AUTH_USER_INFO_BASE64=
VITE_DEV_AUTH_USER_INFO_JSON=