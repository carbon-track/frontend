# API 服务器地址（可选覆盖；未设置时由 Cloudflare Pages 环境自动决定）
# 本地开发默认回退到 https://dev-api.carbontrackapp.com/api/v1
# 如需显式覆盖，可设置为：
# VITE_API_URL=https://dev-api.carbontrackapp.com/api/v1

# Cloudflare Turnstile 站点密钥（前端用）
# 开发可留空以便本地调试；生产必须配置
VITE_TURNSTILE_SITE_KEY=

# Turnstile Configuration (Cloudflare)
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# App Configuration
VITE_APP_NAME=CarbonTrack
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_PASSKEY=false

# CDN/Assets
VITE_ASSETS_URL=
VITE_UPLOAD_URL=

# Default Language
VITE_DEFAULT_LANGUAGE=zh
