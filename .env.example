# API 服务器地址（Cloudflare Pages 与本地均直接读取此值）
# 未设置时，本地构建默认回退到 https://dev-api.carbontrackapp.com/api/v1
# 如需显式指定，可设置为：
# VITE_API_URL=https://dev-api.carbontrackapp.com/api/v1

# Cloudflare Turnstile 站点密钥（前端用）
# 开发可留空以便本地调试；生产必须配置
VITE_TURNSTILE_SITE_KEY=

# Turnstile Configuration (Cloudflare)
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# App Configuration
VITE_APP_NAME=CarbonTrack
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_PASSKEY=false

# Dev-only auth bootstrap (仅本地开发环境生效)
# 建议将以下变量写入 .env.local 或 .env.development.local（不要写入可提交文件）
# 将登录接口返回的 token 填入 VITE_DEV_AUTH_TOKEN
# 将登录接口返回的 user JSON 进行 UTF-8 Base64 编码后填入 VITE_DEV_AUTH_USER_INFO_BASE64
# 也可直接填入 VITE_DEV_AUTH_USER_INFO_JSON（需是合法 JSON 字符串）
# ⚠️ 切勿在生产环境或任何可提交/CI变量中放置真实 token
VITE_ENABLE_DEV_AUTH_FROM_ENV=false
VITE_DEV_AUTH_TOKEN=
VITE_DEV_AUTH_USER_INFO_BASE64=
VITE_DEV_AUTH_USER_INFO_JSON=
VITE_DEV_AUTH_FORCE_SYNC=false

# CDN/Assets
VITE_ASSETS_URL=
VITE_UPLOAD_URL=

# Default Language
VITE_DEFAULT_LANGUAGE=zh
